<Window x:Class="AimAssistPro.Views.CustomDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Precision Aim Assist"
        SizeToContent="Height"
        Width="440"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- Botão Primário — branco -->
        <Style x:Key="DlgPrimaryBtn" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#0A0618"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="White" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="#FFFFFF" BlurRadius="10"
                                                  ShadowDepth="0" Opacity="0.35"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botão Secundario — dark neutral -->
        <Style x:Key="DlgSecondaryBtn" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#242424"
                                BorderBrush="#333333" BorderThickness="1"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2E2E2E"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#505050"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A1A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botão Perigo -->
        <Style x:Key="DlgDangerBtn" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#DC2626" Offset="0"/>
                                    <GradientStop Color="#B91C1C" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#DC2626" BlurRadius="10"
                                                  ShadowDepth="0" Opacity="0.4"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Sombra externa -->
    <Border Margin="12">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="6" Opacity="0.75"/>
        </Border.Effect>

        <!-- Janela principal temática -->
        <Border x:Name="RootBorder" CornerRadius="14"
                BorderBrush="#252525" BorderThickness="1"
                Background="#1A1A1A">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- TitleBar -->
                    <RowDefinition Height="Auto"/>  <!-- Linha accent -->
                    <RowDefinition Height="Auto"/>  <!-- Corpo -->
                    <RowDefinition Height="Auto"/>  <!-- Botões -->
                </Grid.RowDefinitions>

                <!-- ── TitleBar ──────────────────────────── -->
                <Grid Grid.Row="0" Margin="18,14,14,0"
                      MouseLeftButtonDown="TitleBar_MouseDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Ícone + Título -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="26" Height="26" CornerRadius="7"
                            Background="#252525" Margin="0,0,10,0">
                        <Path x:Name="IconPath"
                              Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1Z"
                              Fill="#AAAAAA" Stretch="Uniform" Width="13" Height="13"/>
                    </Border>
                        <TextBlock x:Name="TxtTitle"
                                   Text="PRECISION AIM ASSIST"
                                   FontSize="12" FontWeight="Bold"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Fechar -->
                    <Button Grid.Column="1" Width="26" Height="26"
                            Cursor="Hand" Click="BtnClose_Click"
                            Background="Transparent" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="6" Background="Transparent"
                                        Width="26" Height="26">
                                    <TextBlock Text="✕" Foreground="#555555" FontSize="12"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#282828"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- ── Linha accent degraê ──────────────────────── -->
                <Border Grid.Row="1" Margin="18,10,18,0" Height="1" Background="#252525" CornerRadius="1"/>

                <!-- ── Corpo da mensagem ─────────────────── -->
                <Grid Grid.Row="2" Margin="18,18,18,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Badge ícone -->
                    <Border x:Name="StatusIconBadge"
                            Width="46" Height="46" CornerRadius="12"
                            Background="#252525"
                            Margin="0,0,14,0" VerticalAlignment="Top">
                        <Path x:Name="StatusIconPath"
                              Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1Z"
                              Fill="#AAAAAA" Stretch="Uniform" Width="22" Height="22"/>
                    </Border>

                    <!-- Textos -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtHeading"
                                   Text="Mensagem"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="White"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,6"/>
                        <TextBlock x:Name="TxtBody"
                                   Text=""
                                   FontSize="12"
                                   Foreground="#808080"
                                   TextWrapping="Wrap"
                                   LineHeight="19"/>
                    </StackPanel>
                </Grid>

                <!-- ── Botões ────────────────────────────── -->
                <StackPanel x:Name="ButtonPanel"
                            Grid.Row="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="18,16,18,20"/>
            </Grid>
        </Border>
    </Border>
</Window>
