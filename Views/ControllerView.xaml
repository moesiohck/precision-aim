<UserControl x:Class="AimAssistPro.Views.ControllerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="Transparent"
             Loaded="ControllerView_Loaded"
             Unloaded="ControllerView_Unloaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ Coluna de Dicas ══ -->
        <Grid Grid.Column="0" Background="#0D0D0D" Margin="0,0,0,44">
            <!-- Margem inferior = altura da barra inferior (44px) para não sobrepor -->
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Dicas com scroll invisível -->
            <ScrollViewer Grid.Row="0"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="14,16,14,8">

                    <TextBlock Text="REMAPEAMENTO" Foreground="#505050"
                               FontSize="9" FontFamily="Consolas" FontWeight="Bold"
                               Margin="0,0,0,12"/>

                    <Border Background="#0F0F0F" BorderBrush="#1C1C1C" BorderThickness="1"
                            CornerRadius="8" Padding="11,9" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="① SELECIONAR" Foreground="#505050"
                                       FontSize="9" FontFamily="Consolas" FontWeight="Bold"
                                       Margin="0,0,0,3"/>
                            <TextBlock Text="Clique em qualquer botão do controle para iniciar o remapeamento."
                                       Foreground="#909090" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#0F0F0F" BorderBrush="#1C1C1C" BorderThickness="1"
                            CornerRadius="8" Padding="11,9" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="② CONFIRMAR TECLA" Foreground="#505050"
                                       FontSize="9" FontFamily="Consolas" FontWeight="Bold"
                                       Margin="0,0,0,3"/>
                            <TextBlock Text="Pressione a tecla desejada após selecionar o botão."
                                       Foreground="#909090" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#0F0F0F" BorderBrush="#1C1C1C" BorderThickness="1"
                            CornerRadius="8" Padding="11,9" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="③ RESETAR" Foreground="#505050"
                                       FontSize="9" FontFamily="Consolas" FontWeight="Bold"
                                       Margin="0,0,0,3"/>
                            <TextBlock Text="Selecione um botão e pressione ESC para remover o mapeamento."
                                       Foreground="#909090" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#0F0F0F" BorderBrush="#1C1C1C" BorderThickness="1"
                            CornerRadius="8" Padding="11,9">
                        <StackPanel>
                            <TextBlock Text="④ SALVAMENTO AUTO" Foreground="#505050"
                                       FontSize="9" FontFamily="Consolas" FontWeight="Bold"
                                       Margin="0,0,0,3"/>
                            <TextBlock Text="Os remapeamentos são salvos automaticamente no perfil."
                                       Foreground="#909090" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Aviso fixo no rodapé DO painel (não da tela) -->
            <Border Grid.Row="1" Background="#141000" BorderBrush="#1E1A00"
                    BorderThickness="0,1,0,0" Padding="12,9">
                <TextBlock Foreground="#7A6624" FontSize="11" TextWrapping="Wrap">
                    <Run FontWeight="Bold">⚠ </Run>
                    <Run>Pressione sua tecla selecionada para ativar o aim assist.</Run>
                </TextBlock>
            </Border>
        </Grid>

        <!-- Separador -->
        <Border Grid.Column="0" HorizontalAlignment="Right" Width="1"
                Background="#1A1A1A" Margin="0,0,0,44" Panel.ZIndex="10"/>

        <!-- ══ WebView2 ══ -->
        <wv2:WebView2 Grid.Column="1" x:Name="WebView" Margin="0,0,0,44"/>

        <!-- ── Banner ViGEm ── -->
        <Border x:Name="ViGEmWarningBanner" Grid.Column="1" Visibility="Collapsed"
                VerticalAlignment="Top" Margin="16,10,16,0"
                Background="#7F1E1010" BorderBrush="#EF4444" BorderThickness="1"
                CornerRadius="8" Padding="14,9" Panel.ZIndex="50">
            <StackPanel Orientation="Horizontal">
                <Path Data="M13,14H11V10H13M13,18H11V16H13M1,21H23L12,2L1,21Z"
                      Fill="#EF4444" Stretch="Uniform" Width="18" Height="18" Margin="0,0,10,0"/>
                <StackPanel>
                    <TextBlock Text="⚠ Driver ViGEmBus não detectado!"
                               Foreground="#EF4444" FontWeight="Bold" FontSize="12"/>
                    <TextBlock Text="Instale o driver em Configurações para usar o controle virtual."
                               Foreground="#FCA5A5" FontSize="11"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══ Barra Inferior (fixa) ══ -->
        <Border Grid.ColumnSpan="2" VerticalAlignment="Bottom" Height="44" Panel.ZIndex="200"
                Background="#0D0D0D" BorderBrush="#1E1E1E" BorderThickness="0,1,0,0">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Path Grid.Column="0"
                      Data="M4,6H20A2,2 0 0,1 22,8V16A2,2 0 0,1 20,18H4A2,2 0 0,1 2,16V8A2,2 0 0,1 4,6M4,8V16H20V8H4M7,9H9V11H7V9M11,9H13V11H11V9M15,9H17V15H15V9"
                      Fill="#666666" Stretch="Uniform" Width="16" Height="16" VerticalAlignment="Center"/>

                <Border Grid.Column="2" Background="#1A1A1A" BorderBrush="#2A2A2A" BorderThickness="1"
                        CornerRadius="4" Padding="7,2" VerticalAlignment="Center">
                    <TextBlock x:Name="HotkeyLabel" Text="F8" Foreground="White"
                               FontSize="12" FontWeight="Bold" FontFamily="Consolas"/>
                </Border>

                <TextBlock Grid.Column="4" Text="Ligar/Desligar Controle"
                           Foreground="#666666" FontSize="12" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
