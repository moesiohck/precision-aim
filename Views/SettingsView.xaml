<UserControl x:Class="AimAssistPro.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24">
            <!-- Header -->
            <StackPanel Margin="0,0,0,28">
                <TextBlock Text="Configurações" Style="{StaticResource H1}"/>
                <TextBlock Text="Gerencie sua assinatura, drivers e atalhos" Style="{StaticResource Body}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- License Card -->
            <Border Background="#111111" CornerRadius="10" BorderThickness="1"
                    BorderBrush="{StaticResource BorderDefault}"
                    Margin="0,0,0,24" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock x:Name="PlanText" Text="Standard" FontWeight="SemiBold" FontSize="16" Foreground="White" Margin="0,0,0,4"/>
                        <TextBlock x:Name="ExpiresText" Text="Expira em 15/04/2027" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                            <TextBlock Text="Sua Chave (HWID Locked):" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="KeyText" Text="XXXX-XXXX-XXXX-XXXX" Foreground="{StaticResource AccentSecondary}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                            Content="Renovar" Height="36" MinWidth="90"
                            VerticalAlignment="Center" Click="BtnRenovar_Click"/>
                </Grid>
            </Border>

            <!-- ══════════ GERENCIAMENTO DE DRIVERS ══════════ -->
            <TextBlock Text="Gerenciamento de Drivers" Style="{StaticResource H3}" Margin="0,0,0,12"/>

            <!-- ViGEmBus Card -->
            <Border Background="#111111" CornerRadius="10" BorderThickness="1" x:Name="ViGEmCard" Margin="0,0,0,10" Padding="18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse x:Name="ViGEmDot" Width="10" Height="10" Fill="#22C55E" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Driver ViGEm" FontWeight="Bold" FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Driver necessário para emular o controle Xbox" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="20,0,0,2"/>
                        <TextBlock x:Name="ViGEmStatusText" Text="Status: Instalado e ativo ✓" Foreground="#7A7885" FontSize="11" Margin="20,0,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="BtnUninstallViGEm" Visibility="Collapsed" Background="#7F1515" Foreground="White" BorderThickness="0" Padding="14,8" Cursor="Hand" FontWeight="SemiBold" FontSize="12" Margin="0,0,8,0" Click="BtnUninstallViGEm_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Fill="White" Stretch="Uniform" Width="12" Height="12" Margin="0,0,6,0"/>
                                            <TextBlock Text="Desinstalar" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnInstallViGEm" Background="#303030" Foreground="White" BorderThickness="0" Padding="14,8" Cursor="Hand" FontWeight="SemiBold" FontSize="12" Click="BtnInstallViGEm_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Content>
                                <TextBlock x:Name="BtnInstallViGEmText" Text="Reinstalar"/>
                            </Button.Content>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Interception Card -->
            <Border Background="#111111" CornerRadius="10" BorderThickness="1" x:Name="InterceptionCard" Margin="0,0,0,24" Padding="18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse x:Name="InterceptionDot" Width="10" Height="10" Fill="#EF4444" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Driver Interception" FontWeight="Bold" FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Driver necessário para mapear entradas do teclado e mouse (requer reinicialização)" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="20,0,0,2"/>
                        <TextBlock x:Name="InterceptionStatusText" Text="Status: Não encontrado" Foreground="#7A7885" FontSize="11" Margin="20,0,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="BtnUninstallInterception" Visibility="Collapsed" Background="#7F1515" Foreground="White" BorderThickness="0" Padding="14,8" Cursor="Hand" FontWeight="SemiBold" FontSize="12" Margin="0,0,8,0" Click="BtnUninstallInterception_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Fill="White" Stretch="Uniform" Width="12" Height="12" Margin="0,0,6,0"/>
                                            <TextBlock Text="Desinstalar" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnInstallInterception" Background="#303030" Foreground="White" BorderThickness="0" Padding="14,8" Cursor="Hand" FontWeight="SemiBold" FontSize="12" Click="BtnInstallInterception_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Content>
                                <TextBlock x:Name="BtnInstallInterceptionText" Text="Instalar"/>
                            </Button.Content>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════ OPÇÕES EXTRAS ══════════ -->
            <TextBlock Text="Opções Extras" Style="{StaticResource H3}" Margin="0,0,0,12"/>

            <!-- Stream Mode -->
            <Border Background="#111111" CornerRadius="10" BorderThickness="1" BorderBrush="{StaticResource BorderDefault}" Padding="18,14" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Stream Mode (Ocultar do OBS)" FontWeight="Bold" FontSize="14" Foreground="White" Margin="0,0,0,4"/>
                        <TextBlock Text="Oculta esta janela de softwares de captura de tela, como o OBS Studio (exige que a captura seja Especifica pela Janela)." Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,12" TextWrapping="Wrap"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <CheckBox x:Name="StreamModeToggle" Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" Margin="0,0,0,0" Checked="StreamModeToggle_Changed" Unchecked="StreamModeToggle_Changed"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════ CONFIGURAÇÕES DE CLIP ══════════ -->
            <TextBlock Text="Configurações de Clip" Style="{StaticResource H3}" Margin="0,0,0,12"/>

            <Border Background="#111111" CornerRadius="10" BorderThickness="1" BorderBrush="{StaticResource BorderDefault}" Padding="18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Sequência de Teclas para Clip" FontWeight="Bold" FontSize="14" Foreground="White" Margin="0,0,0,4"/>
                        <TextBlock Text="Configure as teclas que você usa para clipar (ex: Alt, F10, Win, G)" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,12"/>

                        <StackPanel Orientation="Horizontal" x:Name="ClipKeysPanel">
                            <Border Background="#1E1E1E" CornerRadius="6" Padding="10,6" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="F7" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Button Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand" Width="12" Height="12" VerticalAlignment="Center" Click="BtnRemoveClipKey_Click">
                                        <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" Fill="#9CA3AF" Stretch="Uniform"/>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <CheckBox x:Name="ClipToggle" Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" Margin="0,0,0,16"/>
                        <Button Style="{StaticResource SecondaryButton}" Content="Adicionar Tecla" Height="32" Padding="12,0"/>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
