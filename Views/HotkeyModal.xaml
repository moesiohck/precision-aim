<Window x:Class="AimAssistPro.Views.HotkeyModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Selecionar Atalho"
        Width="360" Height="220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Border Background="#111111" CornerRadius="12" BorderBrush="#333333" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="4" Opacity="0.5"/>
        </Border.Effect>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Título -->
            <TextBlock Text="Mudar Atalho (Toggle)" FontSize="16" FontWeight="Bold" Foreground="White" Grid.Row="0"/>
            <Button HorizontalAlignment="Right" VerticalAlignment="Top" Width="24" Height="24"
                    Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnClose_Click" Grid.Row="0">
                <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                      Fill="#666666" Width="10" Height="10" Stretch="Uniform"/>
            </Button>

            <!-- Instrução -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Pressione qualquer tecla agora" Foreground="#888888" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1"
                        CornerRadius="8" Padding="20,10" MinWidth="100" HorizontalAlignment="Center">
                    <TextBlock x:Name="KeyText" Text="F8" Foreground="White" FontSize="18" FontWeight="Bold" FontFamily="Consolas" HorizontalAlignment="Center"/>
                </Border>
            </StackPanel>

            <!-- Salvar -->
            <Button x:Name="BtnSave" Grid.Row="2" Content="Confirmar" Foreground="White" Background="#303030"
                    BorderThickness="0" Height="36" Cursor="Hand" FontWeight="SemiBold" Click="BtnSave_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#404040"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</Window>
