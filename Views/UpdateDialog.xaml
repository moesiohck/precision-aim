<Window x:Class="AimAssistPro.Views.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Precision Aim Assist"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True">

    <Window.Resources>
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#E0E0E0" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="28,11"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="28,11"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Drop shadow outer border -->
    <Border Margin="12" CornerRadius="14"
            Background="#111111"
            BorderBrush="#2A2A2A" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="6" Opacity="0.7"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0" Padding="24,20,24,18"
                    BorderBrush="#1E1E1E" BorderThickness="0,0,0,1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#161616" Offset="0"/>
                        <GradientStop Color="#111111" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Icon -->
                        <Border Width="38" Height="38" CornerRadius="10" Margin="0,0,14,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FFFFFF" Offset="0"/>
                                    <GradientStop Color="#E0E0E0" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="↑" FontSize="20" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="ATUALIZAÇÃO DISPONÍVEL"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="#FFFFFF" />
                            <TextBlock x:Name="TitleText"
                                       Text="Nova versão disponível"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="#F1F1F1" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- Close btn (só visível se não obrigatório) -->
                    <Button x:Name="BtnClose" Content="✕"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Background="Transparent" Foreground="#6B7280"
                            FontSize="14" BorderThickness="0" Cursor="Hand"
                            Click="BtnClose_Click" Padding="6"/>
                </Grid>
            </Border>

            <!-- Body -->
            <Border Grid.Row="1" Padding="24,20,24,4">
            <StackPanel>

                <!-- Version badge row -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="8" Padding="10,8"
                            Background="#1A1A1A" BorderBrush="#2A2A2A" BorderThickness="1">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="ATUAL" FontSize="10" Foreground="#6B7280"
                                       FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="CurrentVersionText" Text="v1.0.0"
                                       FontSize="18" FontWeight="Bold" Foreground="#9CA3AF"
                                       HorizontalAlignment="Center" FontFamily="Consolas"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Grid.Column="1" Text="→" FontSize="20" Foreground="#FFFFFF"
                               VerticalAlignment="Center" Margin="12,0"/>

                    <Border Grid.Column="2" CornerRadius="8" Padding="10,8"
                            BorderThickness="1">
                        <Border.Background>
                            <SolidColorBrush Color="#1A1A1A"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#2A2A2A"/>
                        </Border.BorderBrush>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="NOVA" FontSize="10" Foreground="#888888"
                                       FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="NewVersionText" Text="v1.1.0"
                                       FontSize="18" FontWeight="Bold" Foreground="#FFFFFF"
                                       HorizontalAlignment="Center" FontFamily="Consolas"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Changelog -->
                <Border x:Name="ChangelogBorder" CornerRadius="8" Padding="14,12"
                        Background="#0D0D0D" BorderBrush="#1E1E1E" BorderThickness="1"
                        Margin="0,0,0,20" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="O QUE HÁ DE NOVO" FontSize="10" FontWeight="Bold"
                                   Foreground="#6B7280" Margin="0,0,0,8"/>
                        <TextBlock x:Name="ChangelogText" TextWrapping="Wrap"
                                   FontSize="13" Foreground="#D1D5DB" LineHeight="20"/>
                    </StackPanel>
                </Border>

                <!-- Mandatory warning -->
                <Border x:Name="MandatoryBanner" CornerRadius="8" Padding="12,10"
                        Margin="0,0,0,16" Visibility="Collapsed"
                        Background="#161616" BorderBrush="#3A3A3A" BorderThickness="1">
                    <TextBlock Text="⚠ Esta atualização é obrigatória para continuar usando o app."
                               TextWrapping="Wrap" FontSize="12"
                               Foreground="#D1D5DB"/>
                </Border>
            </StackPanel>
            </Border>

            <!-- Footer buttons -->
            <Border Grid.Row="2" Padding="24,16,24,22">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnSkip" Grid.Column="0"
                            Content="Agora não" Style="{StaticResource BtnSecondary}"
                            Click="BtnSkip_Click"/>
                    <Button x:Name="BtnUpdate" Grid.Column="2"
                            Content="Atualizar agora" Style="{StaticResource BtnPrimary}"
                            Click="BtnUpdate_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
