<Window x:Class="AimAssistPro.Views.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Precision Aim Assist"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True">

    <Window.Resources>
        <Style x:Key="BtnWhite" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0,11"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Background" Value="#333333"/>
                                <Setter Property="Foreground" Value="#666666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="0,11"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1A1A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="10" CornerRadius="14"
            Background="#0C0C0C"
            BorderBrush="#222222" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="32" ShadowDepth="8" Opacity="0.8"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── HEADER ── -->
            <Border Grid.Row="0" Padding="28,24,28,20"
                    BorderBrush="#1A1A1A" BorderThickness="0,0,0,1"
                    CornerRadius="14,14,0,0" Background="#0C0C0C">
                <Grid>
                    <!-- Logo + Título -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="pack://application:,,,/AimAssistPro;component/Resources/logo_p.png"
                               Width="40" Height="40" Margin="0,0,14,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="PRECISION AIM ASSIST"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="#444444"/>
                            <TextBlock Text="Atualização disponível"
                                       FontSize="17" FontWeight="Bold"
                                       Foreground="#FFFFFF" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- Badge OBRIGATÓRIO -->
                    <Border x:Name="MandatoryBadge" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Background="#1E1E1E" BorderBrush="#333333" BorderThickness="1"
                            CornerRadius="5" Padding="8,3" Visibility="Collapsed">
                        <TextBlock Text="OBRIGATÓRIA" FontSize="9" FontWeight="Bold" Foreground="#888888"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ── BODY ── -->
            <Border Grid.Row="1" Padding="28,22,28,8" Background="#0C0C0C">
                <StackPanel>
                    <!-- Versão -->
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" CornerRadius="7" Padding="12,10"
                                Background="#141414" BorderBrush="#222222" BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="ATUAL" FontSize="9" FontWeight="Bold"
                                           Foreground="#444444" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="CurrentVersionText" Text="v1.0.0"
                                           FontSize="20" FontWeight="Bold" Foreground="#666666"
                                           HorizontalAlignment="Center" FontFamily="Consolas"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Grid.Column="1" Text="→" FontSize="18"
                                   Foreground="#333333"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <Border Grid.Column="2" CornerRadius="7" Padding="12,10"
                                Background="#141414" BorderBrush="#333333" BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="NOVA" FontSize="9" FontWeight="Bold"
                                           Foreground="#AAAAAA" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="NewVersionText" Text="v1.2.0"
                                           FontSize="20" FontWeight="Bold" Foreground="#FFFFFF"
                                           HorizontalAlignment="Center" FontFamily="Consolas"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Changelog -->
                    <Border x:Name="ChangelogBorder" CornerRadius="7" Padding="14,12"
                            Background="#111111" BorderBrush="#1E1E1E" BorderThickness="1"
                            Margin="0,0,0,16" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="O QUE HÁ DE NOVO" FontSize="9" FontWeight="Bold"
                                       Foreground="#444444" Margin="0,0,0,8"/>
                            <TextBlock x:Name="ChangelogText"
                                       TextWrapping="Wrap" FontSize="12"
                                       Foreground="#AAAAAA" LineHeight="18"/>
                        </StackPanel>
                    </Border>

                    <!-- Aviso obrigatório -->
                    <Border x:Name="MandatoryWarn" CornerRadius="7" Padding="12,9"
                            Margin="0,0,0,8" Visibility="Collapsed"
                            Background="#141414" BorderBrush="#2A2A2A" BorderThickness="1">
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#888888"
                                   Text="⚠  Atualização obrigatória. O app será encerrado se você fechar esta janela."/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── FOOTER ── -->
            <Border Grid.Row="2" Padding="28,12,28,24" Background="#0C0C0C"
                    CornerRadius="0,0,14,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnSkip" Grid.Column="0"
                            Content="Agora não" Style="{StaticResource BtnGhost}"
                            Click="BtnSkip_Click"/>
                    <Button x:Name="BtnUpdate" Grid.Column="2"
                            Content="Atualizar agora" Style="{StaticResource BtnWhite}"
                            Click="BtnUpdate_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
