<UserControl x:Class="AimAssistPro.Views.MacrosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <!-- Glassmorphism para Macros -->
        <Style x:Key="GlassMacroCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#14FFFFFF"/>
            <Setter Property="BorderBrush" Value="#28FFFFFF"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
        </Style>

        <!-- ScrollBar invisível -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="0"/>
            <Setter Property="Opacity" Value="0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Silhueta sutil -->
        <Image Source="pack://application:,,,/AimAssistPro;component/Resources/controle.png"
               HorizontalAlignment="Center" VerticalAlignment="Center"
               Width="800" Height="800" Stretch="Uniform"
               Margin="0" Opacity="0.05" IsHitTestVisible="False"/>

        <ScrollViewer VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled"
                      PanningMode="VerticalOnly"
                      Margin="0,0,0,8">
            <StackPanel Margin="36,28,36,20">

                <!-- Header -->
                <TextBlock Text="MACRO AUTOMATION LAB" FontSize="11" FontWeight="Bold"
                           Foreground="#888888" FontFamily="Consolas"
                           Margin="4,0,0,4"/>
                <TextBlock Text="Hotkeys e ações automáticas configuradas."
                           Foreground="#666666" FontSize="12" Margin="4,0,0,20"/>

                <!-- Linha: Rapid Fire + Drop Cash -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Rapid Fire -->
                    <Border Grid.Column="0" Style="{StaticResource GlassMacroCard}">
                        <StackPanel>
                            <Grid Margin="20,20,20,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10"
                                        Background="#15FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1"
                                        Margin="0,0,14,0">
                                    <TextBlock Text="⚡" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Rapid Fire" FontSize="15" FontWeight="Black" Foreground="White"/>
                                    <TextBlock Text="Disparo automático máximo" FontSize="11" Foreground="#AAAAAA"/>
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="#15FFFFFF" Margin="0"/>

                            <StackPanel Margin="20,16,20,20">
                                <TextBlock Foreground="#AAAAAA" FontSize="12" LineHeight="18"
                                           TextWrapping="Wrap" Margin="0,0,0,16">
Extrai cadência máxima de <Run Foreground="White" FontWeight="SemiBold">armas semi-automáticas</Run> via simulação do gatilho RT em loop contínuo.
                                </TextBlock>
                                <Border Height="1" Background="#12FFFFFF" Margin="0,0,0,14"/>
                                <Grid>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="MÓDULO" Foreground="#888888" FontSize="10"
                                               FontFamily="Consolas" FontWeight="Bold" Margin="0,0,0,3"/>
                                    <TextBlock Text="Injeção RT Ativa" Foreground="White" FontSize="12"/>
                                    </StackPanel>
                                    <CheckBox x:Name="ToggleRapidFire" Style="{StaticResource ToggleSwitch}"
                                              HorizontalAlignment="Right" VerticalAlignment="Center"
                                              Checked="ToggleRapidFire_Changed" Unchecked="ToggleRapidFire_Changed"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Drop Cash -->
                    <Border Grid.Column="2" Style="{StaticResource GlassMacroCard}">
                        <StackPanel>
                            <Grid Margin="20,20,20,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10"
                                        Background="#15FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1"
                                        Margin="0,0,14,0">
                                    <TextBlock Text="💰" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Fast Drop Cash" FontSize="15" FontWeight="Black" Foreground="White"/>
                                    <TextBlock Text="Ejeção de dinheiro Warzone" FontSize="11" Foreground="#AAAAAA"/>
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="#15FFFFFF" Margin="0"/>

                            <StackPanel Margin="20,16,20,20">
                                <TextBlock Foreground="#AAAAAA" FontSize="12" LineHeight="18"
                                           TextWrapping="Wrap" Margin="0,0,0,14">
Abre o inventário, ejeta todo o <Run Foreground="White" FontWeight="SemiBold">dinheiro</Run> instantaneamente e fecha em fração de segundo.
                                </TextBlock>

                                <Grid Margin="0,0,0,14">
                                    <TextBlock Text="TECLA" Foreground="#888888" FontSize="10"
                                               FontFamily="Consolas" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <Border HorizontalAlignment="Right" Background="#12FFFFFF"
                                            BorderBrush="#22FFFFFF" BorderThickness="1"
                                            CornerRadius="6" MinWidth="64" Padding="12,6"
                                            Cursor="Hand" MouseDown="DropCashKey_MouseDown">
                                        <TextBlock x:Name="TxtDropCashKey" Text="..."
                                                   Foreground="#CCCCCC" FontWeight="Bold"
                                                   FontFamily="Consolas" FontSize="12"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                </Grid>

                                <Border Height="1" Background="#12FFFFFF" Margin="0,0,0,14"/>

                                <Grid>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="MÓDULO" Foreground="#888888" FontSize="10"
                                               FontFamily="Consolas" FontWeight="Bold" Margin="0,0,0,3"/>
                                    <TextBlock Text="Execução Vinculada" Foreground="White" FontSize="12"/>
                                    </StackPanel>
                                    <CheckBox x:Name="ToggleDropCash" Style="{StaticResource ToggleSwitch}"
                                              HorizontalAlignment="Right" VerticalAlignment="Center"
                                              Checked="ToggleDropCash_Changed" Unchecked="ToggleDropCash_Changed"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- RAA — Largura Total, Glass -->
                <Border Style="{StaticResource GlassMacroCard}" Margin="0">
                    <StackPanel Margin="22,24,24,24">
                        <!-- Header Aim Buffed -->
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="46" Height="46" CornerRadius="10"
                                    Background="#15FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1"
                                    Margin="0,0,16,0">
                                <TextBlock Text="🎯" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Aim Buffed" FontSize="18"
                                           FontWeight="Black" Foreground="White"/>
                                <TextBlock Text="Seu Aim Assist mais forte."
                                           FontSize="12" Foreground="#AAAAAA"/>
                            </StackPanel>
                            <CheckBox Grid.Column="2" x:Name="ToggleRAA" Style="{StaticResource ToggleSwitch}"
                                      VerticalAlignment="Center"
                                      Checked="ToggleRAA_Changed" Unchecked="ToggleRAA_Changed"/>
                        </Grid>

                        <Border Height="1" Background="#15FFFFFF" Margin="0,0,0,18"/>

                        <!-- Controle de Força -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Lado esquerdo: info vaga -->  
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,0">
                                <TextBlock Text="MÓDULO PREMIUM" Foreground="#888888" FontSize="11"
                                           FontFamily="Consolas" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock Foreground="#AAAAAA" FontSize="12" LineHeight="20" TextWrapping="Wrap">
Potencializa seu <Run Foreground="White" FontWeight="SemiBold">aim assist</Run> e melhora a precisão de rastreio automaticamente durante partidas.
                                </TextBlock>
                            </StackPanel>

                            <!-- Slider -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="INTENSIDADE" Foreground="#888888" FontSize="10"
                                           FontFamily="Consolas" FontWeight="Bold" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="SliderRAAStrength" Grid.Column="0"
                                            Minimum="0" Maximum="50" TickFrequency="1"
                                            IsSnapToTickEnabled="True" VerticalAlignment="Center"
                                            Margin="0,0,14,0"
                                            ValueChanged="SliderRAAStrength_ValueChanged"/>
                                    <Border Grid.Column="1" Background="#12FFFFFF" BorderBrush="#22FFFFFF"
                                            BorderThickness="1" CornerRadius="6" MinWidth="58" Padding="10,7">
                                        <TextBlock x:Name="TxtRAAStrength" Text="15%"
                                                   Foreground="White" FontWeight="Bold"
                                                   FontFamily="Consolas" FontSize="14"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                </Grid>
                                <Border Background="#0AFFFFFF" BorderBrush="#14FFFFFF" BorderThickness="1"
                                        CornerRadius="8" Padding="12,10" Margin="0,14,0,0">
                                    <TextBlock Foreground="#AAAAAA" FontSize="11" LineHeight="16" TextWrapping="Wrap">
Configure conforme sua preferência. Ajuste gradual recomendado.
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
