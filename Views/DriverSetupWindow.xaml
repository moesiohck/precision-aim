<Window x:Class="AimAssistPro.Views.DriverSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AIM ASSIST PRO — Configuração de Drivers"
        Height="460" Width="560"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Border Background="#0A0A0A" BorderBrush="#505050"
            BorderThickness="1" CornerRadius="12">
        <StackPanel Margin="32">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Border Background="#505050" CornerRadius="8"
                        Width="36" Height="36" Margin="0,0,14,0">
                    <Path Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1M11,7H13V13H11V7M11,15H13V17H11V15Z"
                          Fill="White" Stretch="Uniform" Width="18" Height="18"/>
                </Border>
                <TextBlock Text="Drivers Necessários" FontSize="20"
                           FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="O AIM ASSIST PRO requer dois drivers kernel para funcionar corretamente."
                       Foreground="#9CA3AF" FontSize="12" Margin="0,0,0,24" TextWrapping="Wrap"/>

            <!-- ViGEmBus Card -->
            <Border x:Name="ViGEmCard"
                    Background="#111111" CornerRadius="10"
                    BorderThickness="1" Margin="0,0,0,12" Padding="18,14">
                <Grid>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Ellipse x:Name="ViGEmDot" Width="10" Height="10"
                                     Fill="#EF4444" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="ViGEmBus Driver" FontWeight="Bold"
                                       FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                            <Border x:Name="ViGEmBadge" Background="#1F1F1F"
                                    CornerRadius="4" Padding="8,2" Margin="10,0,0,0">
                                <TextBlock x:Name="ViGEmBadgeText" Text="NÃO INSTALADO"
                                           FontSize="10" FontWeight="Bold" Foreground="#EF4444"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Foreground="#9CA3AF" FontSize="11" TextWrapping="Wrap">
                            Emula um controle Xbox 360 virtual. Sem este driver o controle não aparecerá em nenhum jogo.
                        </TextBlock>
                        <TextBlock Foreground="#6B7280" FontSize="10" Margin="0,4,0,0">
                            Desenvolvido por: Nefarius Software Solutions
                        </TextBlock>
                    </StackPanel>
                    <Button x:Name="BtnInstallViGEm"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Background="#505050" Foreground="White"
                            BorderThickness="0" Padding="16,8" Cursor="Hand"
                            FontWeight="SemiBold" FontSize="12"
                            Click="BtnInstallViGEm_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Content>Baixar e Instalar</Button.Content>
                    </Button>
                </Grid>
            </Border>

            <!-- Interception Card -->
            <Border x:Name="InterceptionCard"
                    Background="#111111" CornerRadius="10"
                    BorderThickness="1" Margin="0,0,0,24" Padding="18,14">
                <Grid>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Ellipse x:Name="InterceptionDot" Width="10" Height="10"
                                     Fill="#EF4444" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Interception Driver" FontWeight="Bold"
                                       FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                            <Border x:Name="InterceptionBadge" Background="#1F1F1F"
                                    CornerRadius="4" Padding="8,2" Margin="10,0,0,0">
                                <TextBlock x:Name="InterceptionBadgeText" Text="NÃO INSTALADO"
                                           FontSize="10" FontWeight="Bold" Foreground="#EF4444"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Foreground="#9CA3AF" FontSize="11" TextWrapping="Wrap">
                            Intercepta entradas de teclado e mouse a nível de kernel. Necessário para mapear teclas com precisão e sem detecção por anti-cheat.
                        </TextBlock>
                        <TextBlock Foreground="#6B7280" FontSize="10" Margin="0,4,0,0">
                            Desenvolvido por: Francisco Lopes (oblitum) — github.com/oblitum/Interception
                        </TextBlock>
                    </StackPanel>
                    <Button x:Name="BtnInstallInterception"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Background="#303030" Foreground="White"
                            BorderThickness="0" Padding="16,8" Cursor="Hand"
                            FontWeight="SemiBold" FontSize="12"
                            Click="BtnInstallInterception_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Content>Ver Instruções</Button.Content>
                    </Button>
                </Grid>
            </Border>

            <!-- Footer Buttons -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center"
                           Foreground="#6B7280" FontSize="11" TextWrapping="Wrap">
                    Você pode continuar sem os drivers, mas o controle virtual não funcionará.
                </TextBlock>

                <Button Grid.Column="2" Content="Continuar Assim Mesmo"
                        Background="Transparent" Foreground="#9CA3AF"
                        BorderBrush="#374151" BorderThickness="1"
                        Padding="16,10" Cursor="Hand" FontSize="12"
                        Click="BtnContinue_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

        </StackPanel>
    </Border>
</Window>
