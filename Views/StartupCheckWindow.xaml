<Window x:Class="AimAssistPro.Views.StartupCheckWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Precision Aim Assist — Verificação"
        Height="470" Width="520"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <!-- Sombra -->
    <Border Margin="8">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="28" ShadowDepth="4" Opacity="0.75"/>
        </Border.Effect>

        <!-- Card principal — cinza muito escuro com borda cinza sutil -->
        <Border Background="#131313" BorderBrush="#323232"
                BorderThickness="1" CornerRadius="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ── Header ─────────────────────────────────────────── -->
                <StackPanel Grid.Row="0" Margin="32,26,32,0">

                    <!-- Logo badge + título em linha -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                Margin="0,0,0,6">
                        <!-- Imagem do Logo -->
                        <Image Source="pack://application:,,,/AimAssistPro;component/Resources/logo_p.png"
                               Width="36" Height="36" Margin="0,0,10,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="PRECISION AIM ASSIST"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="#787878"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="Verificação do Sistema"
                               FontSize="21" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"/>

                    <TextBlock x:Name="TxtSubtitle"
                               Text="Iniciando verificação de componentes..."
                               FontSize="12" Foreground="#686868"
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- ── Progress bar — branca sobre cinza ─────────────── -->
                <Border Grid.Row="1" Margin="32,14,32,0" Height="2"
                        Background="#242424" CornerRadius="1">
                    <Border x:Name="ProgressBar" HorizontalAlignment="Left"
                            Height="2" CornerRadius="1" Width="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#B0B0B0" Offset="0"/>
                                <GradientStop Color="#FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Border>

                <!-- ── Check items ────────────────────────────────────── -->
                <StackPanel Grid.Row="2" Margin="32,18,32,26" VerticalAlignment="Top">

                    <!-- Item 1: Atualizações -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="IconUpdates" Width="34" Height="34"
                                Background="#1E1E1E" CornerRadius="10"
                                HorizontalAlignment="Center">
                            <Path x:Name="PathUpdates"
                                  Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M11,8V12.41L14.29,15.71L15.71,14.29L13,11.59V8H11Z"
                                  Fill="#505050" Stretch="Uniform" Width="16" Height="16"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="2,0,0,0">
                            <TextBlock Text="Verificação de Atualizações"
                                       FontWeight="SemiBold" FontSize="13" Foreground="White"/>
                            <TextBlock x:Name="TxtUpdates"
                                       Text="Aguardando verificação..."
                                       FontSize="11" Foreground="#505050" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Divisor sutil -->
                    <Border Height="1" Background="#1E1E1E" Margin="0,0,0,16" CornerRadius="1"/>

                    <!-- Item 2: Interception -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="IconInterception" Width="34" Height="34"
                                Background="#1E1E1E" CornerRadius="10"
                                HorizontalAlignment="Center">
                            <Path x:Name="PathInterception"
                                  Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M11,8V12.41L14.29,15.71L15.71,14.29L13,11.59V8H11Z"
                                  Fill="#505050" Stretch="Uniform" Width="16" Height="16"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="2,0,0,0">
                            <TextBlock Text="Interception Driver"
                                       FontWeight="SemiBold" FontSize="13" Foreground="White"/>
                            <TextBlock x:Name="TxtInterception"
                                       Text="Aguardando verificação..."
                                       FontSize="11" Foreground="#505050" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Border Height="1" Background="#1E1E1E" Margin="0,0,0,16" CornerRadius="1"/>

                    <!-- Item 3: ViGEmBus -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="IconViGEm" Width="34" Height="34"
                                Background="#1E1E1E" CornerRadius="10"
                                HorizontalAlignment="Center">
                            <Path x:Name="PathViGEm"
                                  Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M11,8V12.41L14.29,15.71L15.71,14.29L13,11.59V8H11Z"
                                  Fill="#505050" Stretch="Uniform" Width="16" Height="16"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="2,0,0,0">
                            <TextBlock Text="ViGEmBus Driver"
                                       FontWeight="SemiBold" FontSize="13" Foreground="White"/>
                            <TextBlock x:Name="TxtViGEm"
                                       Text="Aguardando verificação..."
                                       FontSize="11" Foreground="#505050" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Border Height="1" Background="#1E1E1E" Margin="0,0,0,16" CornerRadius="1"/>

                    <!-- Item 4: Resultado final -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="IconFinal" Width="34" Height="34"
                                Background="#1E1E1E" CornerRadius="10"
                                HorizontalAlignment="Center">
                            <Path x:Name="PathFinal"
                                  Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M11,8V12.41L14.29,15.71L15.71,14.29L13,11.59V8H11Z"
                                  Fill="#505050" Stretch="Uniform" Width="16" Height="16"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="2,0,0,0">
                            <TextBlock Text="Resultado Final"
                                       FontWeight="SemiBold" FontSize="13" Foreground="White"/>
                            <TextBlock x:Name="TxtFinal"
                                       Text="Aguardando verificação..."
                                       FontSize="11" Foreground="#505050" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
