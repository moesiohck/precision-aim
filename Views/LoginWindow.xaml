<Window x:Class="AimAssistPro.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Precision Aim Assist"
        Width="860" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">



    <!-- Container: cantos arredondados em todos os 4 lados -->
    <Border Background="#0A0A0A" CornerRadius="20" ClipToBounds="True">
        <Grid>

            <!-- IMAGEM DO CONTROLE — direita, sem nenhum outro elemento cobrindo -->
            <Image Source="pack://application:,,,/AimAssistPro;component/Resources/controle.png"
                   HorizontalAlignment="Right" VerticalAlignment="Center"
                   Width="480" Height="480" Stretch="Uniform"
                   Margin="0,0,10,0"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   IsHitTestVisible="False" Opacity="1"/>

            <!-- Overlay gradiente escuro → transparente (sem banding) -->
            <Rectangle IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#0A0A0A"   Offset="0"/>
                        <GradientStop Color="#0A0A0A"   Offset="0.40"/>
                        <GradientStop Color="#C80A0A0A" Offset="0.54"/>
                        <GradientStop Color="#700A0A0A" Offset="0.67"/>
                        <GradientStop Color="#200A0A0A" Offset="0.80"/>
                        <GradientStop Color="#000A0A0A" Offset="0.92"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Drag area -->
            <Rectangle Fill="Transparent" VerticalAlignment="Top" Height="52"
                       MouseLeftButtonDown="TitleBar_MouseDown"/>

            <!-- Botão fechar -->
            <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,14,16,0" Width="30" Height="30"
                    Cursor="Hand" Click="BtnClose_Click"
                    Panel.ZIndex="100"
                    Background="Transparent" BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8"
                                Background="Transparent" Width="30" Height="30">
                            <Path x:Name="Icon" Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                                  Fill="#505050" Width="13" Height="13" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1F1F1F"/>
                                <Setter TargetName="Icon" Property="Fill" Value="#EF4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- ═══════════════════ FORMULÁRIO ═══════════════════ -->
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center"
                        Width="320" Margin="52,0,0,0">

                <!-- Logo badge -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,28">
                    <Image Source="pack://application:,,,/AimAssistPro;component/Resources/logo_p.png"
                           Width="32" Height="32" Margin="0,0,10,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="PRECISION AIM ASSIST" Foreground="#777777"
                               FontSize="11" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Título + subtítulo -->
                <TextBlock Text="ENTRAR" Foreground="White"
                           FontSize="22" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock Text="Acesse sua conta para continuar"
                           Foreground="#909090" FontSize="12" Margin="0,0,0,26"/>

                <!-- Campo Email -->
                <Border x:Name="EmailBorder" Height="48"
                        Background="#141414" BorderBrush="#2E2E2E" BorderThickness="1"
                        CornerRadius="10" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0"
                              Data="M20,8L12,13L4,8V6L12,11L20,6M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.1,4 20,4Z"
                              Fill="#555555" Width="16" Height="16" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Grid Grid.Column="1" Margin="0,0,14,0">
                            <TextBlock x:Name="EmailPlaceholder" Text="Email"
                                       Foreground="#555555" FontSize="13"
                                       Margin="4,0,0,0"
                                       VerticalAlignment="Center" IsHitTestVisible="False"/>
                            <TextBox x:Name="UsernameInput"
                                     Background="Transparent" Foreground="White"
                                     BorderThickness="0" FontSize="13" Padding="4,0,0,0" Margin="0"
                                     CaretBrush="#AAAAAA" SelectionBrush="#606060"
                                     VerticalAlignment="Center"
                                     FocusVisualStyle="{x:Null}"
                                     GotFocus="EmailInput_GotFocus"
                                     LostFocus="EmailInput_LostFocus"
                                     KeyDown="Input_KeyDown"
                                     TextChanged="UsernameInput_TextChanged">
                                <TextBox.Template>
                                    <ControlTemplate TargetType="TextBox">
                                        <ScrollViewer x:Name="PART_ContentHost"
                                                      VerticalScrollBarVisibility="Hidden"
                                                      HorizontalScrollBarVisibility="Hidden"
                                                      VerticalAlignment="Center"/>
                                    </ControlTemplate>
                                </TextBox.Template>
                            </TextBox>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Campo Senha -->
                <Border x:Name="PassBorder" Height="48"
                        Background="#141414" BorderBrush="#2E2E2E" BorderThickness="1"
                        CornerRadius="10" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0"
                              Data="M12,17A2,2 0 0,0 14,15C14,13.89 13.1,13 12,13A2,2 0 0,0 10,15A2,2 0 0,0 12,17M18,8A2,2 0 0,1 20,10V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V10C4,8.89 4.9,8 6,8H7V6A5,5 0 0,1 12,1A5,5 0 0,1 17,6V8H18M12,3A3,3 0 0,0 9,6V8H15V6A3,3 0 0,0 12,3Z"
                              Fill="#555555" Width="16" Height="16" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Grid Grid.Column="1" Margin="0,0,14,0">
                            <TextBlock x:Name="PassPlaceholder" Text="Senha"
                                       Foreground="#555555" FontSize="13"
                                       Margin="4,0,0,0"
                                       VerticalAlignment="Center" IsHitTestVisible="False"/>
                            <PasswordBox x:Name="PasswordInput"
                                         Background="Transparent" Foreground="White"
                                         BorderThickness="0" FontSize="13" Padding="4,0,0,0" Margin="0"
                                         CaretBrush="#AAAAAA"
                                         VerticalAlignment="Center"
                                         FocusVisualStyle="{x:Null}"
                                         GotFocus="PassInput_GotFocus"
                                         LostFocus="PassInput_LostFocus"
                                         KeyDown="Input_KeyDown"
                                         PasswordChanged="PasswordInput_PasswordChanged">
                                <PasswordBox.Template>
                                    <ControlTemplate TargetType="PasswordBox">
                                        <ScrollViewer x:Name="PART_ContentHost"
                                                      VerticalScrollBarVisibility="Hidden"
                                                      HorizontalScrollBarVisibility="Hidden"
                                                      VerticalAlignment="Center"/>
                                    </ControlTemplate>
                                </PasswordBox.Template>
                            </PasswordBox>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Erro -->
                <TextBlock x:Name="ErrorText" Text="" Foreground="#F87171"
                           FontSize="11" Margin="0,-12,0,12"
                           TextWrapping="Wrap" Visibility="Collapsed"/>

                <!-- Botão ENTRAR -->
                <Button x:Name="BtnLogin" Height="48"
                        Cursor="Hand" Click="BtnLogin_Click" Margin="0,0,0,16">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" CornerRadius="10">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FFFFFF" Offset="0"/>
                                        <GradientStop Color="#D0D0D0" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="ENTRAR" FontSize="13" FontWeight="Bold"
                                           Foreground="#0A0A0A"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.88"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.72"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.38"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Loading -->
                <TextBlock x:Name="LoadingText" Text="Verificando..."
                           Foreground="#606060" FontSize="11"
                           HorizontalAlignment="Center"
                           Margin="0,-8,0,8" Visibility="Collapsed"/>

                <!-- Link criar conta -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Não tem conta? " Foreground="#666666" FontSize="11"/>
                    <TextBlock Text="Criar conta" Foreground="#AAAAAA"
                               FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                               MouseLeftButtonDown="OpenPortal_Click">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Copyright -->
                <TextBlock Text="© 2026 Precision Aim Assist · Todos os direitos reservados"
                           Foreground="#555555" FontSize="10" Margin="0,20,0,0"/>

            </StackPanel>

        </Grid>
    </Border>
</Window>