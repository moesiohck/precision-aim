<Window x:Class="AimAssistPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PRECISION AIM ASSIST" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">



    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="48" CornerRadius="14"
                      ResizeBorderThickness="0"
                      GlassFrameThickness="-1"/>
    </WindowChrome.WindowChrome>

    <!-- Main Container -->
    <Border x:Name="MainBorder" CornerRadius="14" Background="#0C0C0C"
            BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
            ClipToBounds="True"
            SizeChanged="MainBorder_SizeChanged">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>  <!-- Top bar (taller for floating effect) -->
                <RowDefinition Height="*"/>   <!-- Content -->
                <RowDefinition Height="Auto"/>  <!-- Bottom bar -->
            </Grid.RowDefinitions>

            <!-- ══════════ TOP BAR ══════════ -->
            <Border Grid.Row="0" Background="Transparent" CornerRadius="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>  <!-- Logo -->
                        <ColumnDefinition Width="*"/>     <!-- Tabs center -->
                        <ColumnDefinition Width="Auto"/>  <!-- Window buttons / Profile -->
                    </Grid.ColumnDefinitions>

                    <!-- Logo & Plan -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="24,0">
                        <Image Source="pack://application:,,,/AimAssistPro;component/Resources/logo_p.png"
                               Width="42" Height="42" Margin="0,0,12,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="PRECISION AIM" FontSize="15" FontWeight="Black"
                                       Foreground="White"/>
                            <TextBlock Text="ASSIST" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentSecondary}" Margin="0,-2,0,0"/>
                            <TextBlock Text="v1.2.4 Beta" FontSize="9" Foreground="#555555" Margin="0,1,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Center Tabs (Underline Style) -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
                               WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button x:Name="TabDashboard" Content="Dashboard"
                                    Style="{StaticResource NavTabButton}"
                                    Width="110" Height="36" Click="TabDashboard_Click" Tag="active"/>
                            <Button x:Name="TabRemapear" Content="Remapear"
                                    Style="{StaticResource NavTabButton}"
                                    Width="110" Height="36" Click="TabRemapear_Click"/>
                            <Button x:Name="TabMacros" Content="Macros"
                                    Style="{StaticResource NavTabButton}"
                                    Width="120" Height="36" Click="TabMacros_Click"/>
                    </StackPanel>

                    <!-- Profile & Window Controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,16,0"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                                
                        <!-- Profile Avatar -->
                        <StackPanel x:Name="ProfilePanel" Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonDown="ProfileAvatar_Click" Background="Transparent" ToolTip="Ver detalhes da conta">
                            <TextBlock x:Name="ProfileNameText" Text="User" FontSize="14" FontWeight="Bold" Foreground="#EDEDED" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Border Width="36" Height="36" CornerRadius="18" Background="#282828" BorderBrush="#505050" BorderThickness="2">
                                <TextBlock x:Name="ProfileInitialsText" Text="U" FontSize="15" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>

                        <Popup x:Name="ProfilePopup" StaysOpen="True" AllowsTransparency="True" PopupAnimation="Fade"
                               PlacementTarget="{Binding ElementName=ProfilePanel}" Placement="Bottom"
                               VerticalOffset="12" HorizontalOffset="-50">
                            <Border Background="#1C1C1C" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="10" Width="220" Padding="14">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000" BlurRadius="28" ShadowDepth="8" Opacity="0.85"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <TextBlock Text="INFORMAÇÕES DA CONTA" FontSize="10" FontWeight="Bold" Foreground="#777" VerticalAlignment="Center"/>
                                        <!-- Botão fechar popup -->
                                        <Button HorizontalAlignment="Right" Background="Transparent" BorderThickness="0"
                                                Cursor="Hand" Click="CloseProfilePopup_Click" Padding="2" Margin="0,-2,-2,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bx" Background="Transparent" CornerRadius="5" Padding="4,2">
                                                        <TextBlock Text="×" Foreground="#555" FontSize="13"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bx" Property="Background" Value="#2A2A2A"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>

                                    <!-- User Data -->
                                    <TextBlock x:Name="PopupUsername" Text="moesiohck" FontSize="15" FontWeight="ExtraBold" Foreground="White" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="PopupEmail" Text="moesio@email.com" FontSize="11" Foreground="#888" Margin="0,0,0,12"/>

                                    <!-- License Badge -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Border Background="#2B1D05" BorderBrush="#D97706" BorderThickness="1" CornerRadius="4" Padding="5,2" VerticalAlignment="Center">
                                            <TextBlock x:Name="PopupPlan" Text="LIFETIME" FontSize="10" FontWeight="Bold" Foreground="#F59E0B"/>
                                        </Border>
                                        <TextBlock x:Name="PopupExpires" Text="Licença vitalícia" FontSize="11" Foreground="#A3A3A3" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    </StackPanel>

                                    <!-- Key + HWID -->
                                    <StackPanel Margin="0,0,0,6">
                                        <TextBlock Text="CHAVE DE ATIVAÇÃO" FontSize="9" FontWeight="Bold"
                                                   Foreground="#555" FontFamily="Consolas" Margin="0,0,0,2"/>
                                        <TextBlock x:Name="PopupKey" Text="—" FontSize="10"
                                                   Foreground="#999" FontFamily="Consolas" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="HARDWARE ID" FontSize="9" FontWeight="Bold"
                                                   Foreground="#555" FontFamily="Consolas" Margin="0,0,0,2"/>
                                        <TextBlock x:Name="PopupHwid" Text="—" FontSize="9"
                                                   Foreground="#666" FontFamily="Consolas" TextWrapping="Wrap"
                                                   IsHitTestVisible="False"/>
                                    </StackPanel>

                                    <!-- Divisor -->
                                    <Border Height="1" Background="#2A2A2A" Margin="-14,0,-14,8" CornerRadius="1"/>

                                    <!-- Logout Button -->
                                    <Button Content="Sair da Conta" Foreground="#F87171" Background="Transparent" BorderThickness="0"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                            FontWeight="SemiBold" FontSize="13" Cursor="Hand" Click="MenuLogout_Click" Padding="6,8" Margin="-6,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#2A1616"/>
                                                        <Setter Property="Foreground" Value="#FCA5A5"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#3D1515"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Popup>
                        
                        <!-- Window Controls -->
                        <Button Style="{StaticResource WindowButton}" Click="BtnDiscord_Click" ToolTip="Entrar no Discord">
                            <Path Data="{StaticResource DiscordIcon}" Stroke="Transparent" Fill="#5865F2"
                                  Width="18" Height="14" Stretch="Uniform"/>
                        </Button>
                        <Button Style="{StaticResource WindowButton}" Click="BtnSettings_Click" ToolTip="Configurações">
                            <Path Data="{StaticResource SettingsIcon}" Stroke="Transparent" Fill="{StaticResource TextSecondary}"
                                  Width="14" Height="14" Stretch="Uniform"/>
                        </Button>
                        <Border Width="1" Height="16" Background="#2E2E2E" Margin="4,0" VerticalAlignment="Center"/>
                        
                        <Button Style="{StaticResource WindowButton}" Click="BtnMinimize_Click">
                            <Path Data="M4,12 L20,12" Stroke="{StaticResource TextSecondary}"
                                  StrokeThickness="1.5" Width="12" Height="12" Stretch="Uniform"/>
                        </Button>
                        <!-- Botão Maximizar removido a pedido do usuário -->
                        <Button Style="{StaticResource WindowCloseButton}" Click="BtnClose_Click">
                            <Path Data="M4,4 L20,20 M20,4 L4,20" Stroke="White"
                                  StrokeThickness="1.5" Width="10" Height="10" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════ CONTENT ══════════ -->
            <Frame x:Name="MainFrame" Grid.Row="1"
                   NavigationUIVisibility="Hidden"
                   Background="Transparent"/>

        </Grid>
    </Border>
</Window>
