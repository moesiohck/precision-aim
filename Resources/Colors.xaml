<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════
         BACKGROUND LAYERS — Cinza escuro / preto elegante
    ═══════════════════════════════════════════════════════ -->
    <Color x:Key="BgDeepColor">#0A0A0A</Color>
    <Color x:Key="BgBaseColor">#111111</Color>
    <Color x:Key="BgSurfaceColor">#181818</Color>
    <Color x:Key="BgCardColor">#202020</Color>
    <Color x:Key="BgCard2Color">#282828</Color>
    <Color x:Key="BgElevatedColor">#303030</Color>

    <!-- ═══════════════════════════════════════════════════════
         ACCENT — Branco / Prata (identidade da logo)
    ═══════════════════════════════════════════════════════ -->
    <Color x:Key="AccentPrimaryColor">#E8E8E8</Color>
    <Color x:Key="AccentSecondaryColor">#C0C0C0</Color>
    <Color x:Key="AccentTertiaryColor">#A0A0A0</Color>
    <Color x:Key="AccentGlowColor">#FFFFFF</Color>

    <!-- ═══════════════════════════════════════════════════════
         HIGHLIGHT — Cinza médio para hover/destaque
    ═══════════════════════════════════════════════════════ -->
    <Color x:Key="CyanColor">#909090</Color>
    <Color x:Key="CyanDarkColor">#707070</Color>
    <Color x:Key="CyanGlowColor">#B8B8B8</Color>

    <!-- ═══════════════════════════════════════════════════════
         STATUS COLORS — mantidos vibrantes para legibilidade
    ═══════════════════════════════════════════════════════ -->
    <Color x:Key="SuccessColor">#22C55E</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="DangerColor">#EF4444</Color>
    <Color x:Key="InfoColor">#D4D4D4</Color>

    <!-- ═══════════════════════════════════════════════════════
         TEXT — Branco puro sobre fundo escuro
    ═══════════════════════════════════════════════════════ -->
    <Color x:Key="TextPrimaryColor">#FFFFFF</Color>
    <Color x:Key="TextSecondaryColor">#C8C8C8</Color>
    <Color x:Key="TextMutedColor">#787878</Color>
    <Color x:Key="TextDisabledColor">#484848</Color>

    <!-- ═══════════════════════════════════════════════════════
         BORDERS — Tons de cinza para separação sutil
    ═══════════════════════════════════════════════════════ -->
    <Color x:Key="BorderSubtleColor">#242424</Color>
    <Color x:Key="BorderDefaultColor">#363636</Color>
    <Color x:Key="BorderStrongColor">#505050</Color>

    <!-- ═══════════════════════════════════════════════════════
         SOLID BRUSHES
    ═══════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="BgDeep"         Color="{StaticResource BgDeepColor}"/>
    <SolidColorBrush x:Key="BgBase"         Color="{StaticResource BgBaseColor}"/>
    <SolidColorBrush x:Key="BgSurface"      Color="{StaticResource BgSurfaceColor}"/>
    <SolidColorBrush x:Key="BgCard"         Color="{StaticResource BgCardColor}"/>
    <SolidColorBrush x:Key="BgCard2"        Color="{StaticResource BgCard2Color}"/>
    <SolidColorBrush x:Key="BgElevated"     Color="{StaticResource BgElevatedColor}"/>

    <SolidColorBrush x:Key="AccentPrimary"  Color="{StaticResource AccentPrimaryColor}"/>
    <SolidColorBrush x:Key="AccentSecondary" Color="{StaticResource AccentSecondaryColor}"/>
    <SolidColorBrush x:Key="AccentTertiary" Color="{StaticResource AccentTertiaryColor}"/>
    <SolidColorBrush x:Key="AccentGlow"     Color="{StaticResource AccentGlowColor}"/>

    <SolidColorBrush x:Key="Cyan"           Color="{StaticResource CyanColor}"/>
    <SolidColorBrush x:Key="CyanDark"       Color="{StaticResource CyanDarkColor}"/>
    <SolidColorBrush x:Key="CyanGlow"       Color="{StaticResource CyanGlowColor}"/>

    <SolidColorBrush x:Key="Success"        Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="Warning"        Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="Danger"         Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="Info"           Color="{StaticResource InfoColor}"/>

    <SolidColorBrush x:Key="TextPrimary"    Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondary"  Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMuted"      Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextDisabled"   Color="{StaticResource TextDisabledColor}"/>

    <SolidColorBrush x:Key="BorderSubtle"   Color="{StaticResource BorderSubtleColor}"/>
    <SolidColorBrush x:Key="BorderDefault"  Color="{StaticResource BorderDefaultColor}"/>
    <SolidColorBrush x:Key="BorderStrong"   Color="{StaticResource BorderStrongColor}"/>

    <!-- ═══════════════════════════════════════════════════════
         GRADIENT BRUSHES — Gradientes em tons de cinza/branco
    ═══════════════════════════════════════════════════════ -->
    <!-- Gradiente principal do accent (branco → cinza) -->
    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#909090" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGradientV" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#E8E8E8" Offset="0"/>
        <GradientStop Color="#C0C0C0" Offset="1"/>
    </LinearGradientBrush>

    <!-- Sidebar: preto absoluto → cinza muito escuro -->
    <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0A0A0A" Offset="0"/>
        <GradientStop Color="#111111" Offset="1"/>
    </LinearGradientBrush>

    <!-- Card: gradiente sutil de profundidade -->
    <LinearGradientBrush x:Key="CardGlowGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#242424" Offset="0"/>
        <GradientStop Color="#1A1A1A" Offset="1"/>
    </LinearGradientBrush>

    <!-- Glow sutil branco translúcido -->
    <RadialGradientBrush x:Key="GlowBrush" GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
        <GradientStop Color="#30FFFFFF" Offset="0"/>
        <GradientStop Color="#00FFFFFF" Offset="1"/>
    </RadialGradientBrush>

    <!-- Nav ativo: faixa branca translúcida -->
    <LinearGradientBrush x:Key="ActiveNavGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#25FFFFFF" Offset="0"/>
        <GradientStop Color="#00FFFFFF" Offset="1"/>
    </LinearGradientBrush>

    <!-- Botão principal: cinza escuro → preto -->
    <LinearGradientBrush x:Key="ButtonGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#3A3A3A" Offset="0"/>
        <GradientStop Color="#1E1E1E" Offset="1"/>
    </LinearGradientBrush>

    <!-- Botão hover: cinza médio -->
    <LinearGradientBrush x:Key="ButtonHoverGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#505050" Offset="0"/>
        <GradientStop Color="#383838" Offset="1"/>
    </LinearGradientBrush>

    <!-- Sucesso: verde mantido -->
    <LinearGradientBrush x:Key="SuccessGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#34D399" Offset="0"/>
        <GradientStop Color="#10B981" Offset="1"/>
    </LinearGradientBrush>

    <!-- Perigo: vermelho mantido -->
    <LinearGradientBrush x:Key="DangerGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#F87171" Offset="0"/>
        <GradientStop Color="#EF4444" Offset="1"/>
    </LinearGradientBrush>

    <!-- ═══════════════════════════════════════════════════════
         COMBOBOX — Dropdown escuro
         WPF abre/fecha nativamente via OnMouseLeftButtonDown interno.
         Nao usar ToggleButton - causa double-toggle (abre e fecha no mesmo click).
    ═══════════════════════════════════════════════════════ -->
    <Style TargetType="ComboBox">
        <Setter Property="Background"       Value="#111111"/>
        <Setter Property="Foreground"       Value="White"/>
        <Setter Property="BorderBrush"      Value="#2A2A2A"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Height"           Value="40"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <!-- O botão invisível resolve o problema de o ComboBox nao abrir ao clicar no template customizado -->
                        <ToggleButton IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      Background="Transparent" BorderThickness="0">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="Transparent" />
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        
                        <!-- Caixa visual principal -->
                        <Border x:Name="MainBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                IsHitTestVisible="False">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="32"/>
                                </Grid.ColumnDefinitions>
                                <!-- Item selecionado -->
                                <ContentPresenter Grid.Column="0"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  IsHitTestVisible="False"
                                                  Margin="14,0,0,0"
                                                  VerticalAlignment="Center"/>
                                <!-- Seta -->
                                <Path Grid.Column="1"
                                      Data="M7,10L12,15L17,10H7Z"
                                      Fill="#888888" Width="12" Height="12" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                        <!-- Popup — WPF seta IsDropDownOpen, este popup reflete -->
                        <Popup x:Name="PART_Popup"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Fade"
                               StaysOpen="False">
                            <Border Background="#161616"
                                    BorderBrush="#333333" BorderThickness="1"
                                    CornerRadius="6" Margin="0,3,0,0"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="280">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="14"
                                                      ShadowDepth="3" Opacity="0.7"/>
                                </Border.Effect>
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              CanContentScroll="True">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="#444444"/>
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="#555555"/>
                            <Setter TargetName="MainBorder" Property="Background"  Value="#181818"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="Foreground"       Value="#CCCCCC"/>
        <Setter Property="Padding"          Value="14,9"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="FontSize"         Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#252525"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#1E1E1E"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- ToolTip escuro -->
    <Style TargetType="ToolTip">
        <Setter Property="Background"      Value="#1A1A1A"/>
        <Setter Property="Foreground"      Value="#CCCCCC"/>
        <Setter Property="BorderBrush"     Value="#333333"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="12,8"/>
        <Setter Property="HasDropShadow"   Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="#1A1A1A"
                            BorderBrush="#333333" BorderThickness="1"
                            CornerRadius="8" Padding="12,8"
                            MaxWidth="340">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="3" Opacity="0.5"/>
                        </Border.Effect>
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════
         TEXTBOX global — remove orange focus ring
    ═══════════════════════════════════════════════════════ -->
    <Style TargetType="TextBox">
        <Setter Property="FocusVisualStyle"          Value="{x:Null}"/>
        <Setter Property="Background"                Value="Transparent"/>
        <Setter Property="Foreground"                Value="White"/>
        <Setter Property="BorderThickness"           Value="0"/>
        <Setter Property="CaretBrush"                Value="#AAAAAA"/>
        <Setter Property="SelectionBrush"            Value="#606060"/>
        <Setter Property="VerticalContentAlignment"  Value="Center"/>
    </Style>

    <!-- PASSWORDBOX global — remove orange focus ring -->
    <Style TargetType="PasswordBox">
        <Setter Property="FocusVisualStyle"          Value="{x:Null}"/>
        <Setter Property="Background"                Value="Transparent"/>
        <Setter Property="Foreground"                Value="White"/>
        <Setter Property="BorderThickness"           Value="0"/>
        <Setter Property="CaretBrush"                Value="#AAAAAA"/>
        <Setter Property="VerticalContentAlignment"  Value="Center"/>
    </Style>

</ResourceDictionary>

